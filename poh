#include <Adafruit_Sensor.h>
#include <DHT_U.h>
#include <WiFi.h>
#include <WiFiClientSecure.h>
#include <PubSubClient.h>
#include <ESP32Servo.h> 
#include <FastLED.h> 

// Defining Pins
#define LED D0
#define DHTPIN D1
#define SERVO_PIN D2
#define LED_PIN D3
#define NUM_LEDS 16
#define DUST_PIN D8 
#define OLED_SDA D4
#define OLED_SCL D5
#define TURB D7     

// DHT parameters
#define DHTTYPE DHT22
DHT_Unified dht(DHTPIN, DHTTYPE);
float temp, hum;
const long interval = 5000; // Publish every 5 seconds

// Servo motor
Servo servo;

// WS2812 LED strip
CRGB leds[NUM_LEDS];

// Global variables to store current color states for the NeoPixels
String currentTempColor = "green";
String currentHumColor = "green";
String currentDustColor = "green";
String currentTurbColor = "green";

// Wi-Fi credentials
const char* ssid = "Wokwi-GUEST";
const char* password = "";

// MQTT broker details
const char* mqtt_broker = "check node";
const int mqtt_port = 8883;
const char* mqtt_username = "helloworld";
const char* mqtt_password = "Hello2world";
const char* topic = "Tempdata"; 

// Create instances
WiFiClientSecure wifiClient;
PubSubClient mqttClient(wifiClient);

long previous_time = 0;

void mqttCallback(char* topic, byte* payload, unsigned int length) {
  String message;
  for (int i = 0; i < length; i++) {
    message += (char)payload[i];
  }
  
  if (String(topic) == "lights") {
    if (message == "ON") digitalWrite(LED, HIGH);
    else digitalWrite(LED, LOW);
  }
  else if (String(topic) == "servo") {
    int degree = message.toInt();
    servo.write(degree);
  }
  // The "lights/neopixel" MQTT callback is kept here if you want to override it manually later
}

void setupMQTT(){
  mqttClient.setServer(mqtt_broker, mqtt_port);
  mqttClient.setCallback(mqttCallback);
}

void reconnect(){
  while (!mqttClient.connected()){
    Serial.println("Reconnecting to MQTT...");
    String clientId = "ESP32Client-";
    clientId += String(random(0xffff),HEX);

    if (mqttClient.connect(clientId.c_str(), mqtt_username, mqtt_password)) {
      mqttClient.subscribe("lights");
      mqttClient.subscribe("servo");
      mqttClient.subscribe("lights/neopixel");
    } else {
      delay(5000);
    }
  }
}

// --- HELPER FUNCTION: Convert String to FastLED Color (With Blinking) ---
CRGB getColorFromString(String colorStr) {
  // This creates a 1Hz blink effect without using delay()
  bool isBlinkOn = (millis() % 1000) < 500; 

  if (colorStr == "red")    return CRGB::Red;
  if (colorStr == "bred")   return isBlinkOn ? CRGB::Red : CRGB::Black;
  if (colorStr == "blue")   return CRGB::Blue;
  if (colorStr == "bblue")  return isBlinkOn ? CRGB::Blue : CRGB::Black;
  if (colorStr == "yellow") return CRGB::Yellow;
  if (colorStr == "orange") return CRGB::Orange;
  if (colorStr == "green")  return CRGB::Green;
  
  return CRGB::Black; // Safe default
}

// --- HELPER FUNCTION: Update the 4 Physical LED Segments ---
void updatePhysicalLEDs() {
  CRGB tempC = getColorFromString(currentTempColor);
  CRGB humC  = getColorFromString(currentHumColor);
  CRGB dustC = getColorFromString(currentDustColor);
  CRGB turbC = getColorFromString(currentTurbColor);

  // Segment 1: Temperature (LEDs 0 to 3)
  for(int i = 0; i < 4; i++) leds[i] = tempC;
  
  // Segment 2: Humidity (LEDs 4 to 7)
  for(int i = 4; i < 8; i++) leds[i] = humC;
  
  // Segment 3: Dust (LEDs 8 to 11)
  for(int i = 8; i < 12; i++) leds[i] = dustC;
  
  // Segment 4: Turbidity (LEDs 12 to 15)
  for(int i = 12; i < 16; i++) leds[i] = turbC;

  FastLED.show();
}

void setup() {
  Serial.begin(115200);
  pinMode(LED, OUTPUT);
  pinMode(DUST_PIN, INPUT);
  pinMode(TURB, INPUT);
  
  dht.begin();
  servo.attach(SERVO_PIN, 500, 2400);
  servo.write(0);
  
  // Initialize FastLED
  FastLED.addLeds<WS2812, LED_PIN, GRB>(leds, NUM_LEDS);
  FastLED.setBrightness(50); // Set to 50 to prevent blinding/power spikes

  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) { delay(500); }
  
  wifiClient.setInsecure(); 
  setupMQTT();
}

void loop() {
  if (!mqttClient.connected()) reconnect();
  mqttClient.loop();

  // 1. Constantly update the physical LEDs (Required for smooth blinking animation)
  updatePhysicalLEDs();

  // 2. Read sensors and publish ONLY every 5 seconds
  long now = millis();
  if (now - previous_time > interval) { 
    previous_time = now;

    // Read Sensors
    sensors_event_t event;
    dht.temperature().getEvent(&event);
    temp = isnan(event.temperature) ? 25.0 : event.temperature; 
    
    dht.humidity().getEvent(&event);
    hum = isnan(event.relative_humidity) ? 50.0 : event.relative_humidity; 
    
    int dustVal = analogRead(DUST_PIN);
    int turbVal = analogRead(TURB);

    // Evaluate Colors (Now updating the GLOBAL variables)
    currentTempColor = "green";
    if (temp >= 35.0) currentTempColor = "red";
    else if (temp <= 18.0) currentTempColor = "bred";

    currentHumColor = "green";
    if (hum >= 80.0) currentHumColor = "blue";
    else if (hum <= 40.0) currentHumColor = "bblue";

    currentDustColor = "green";
    if (dustVal >= 150) currentDustColor = "yellow"; 

    currentTurbColor = "green";
    if (turbVal >= 2000) currentTurbColor = "orange"; 

    // Construct the comprehensive JSON payload
    String jsonPayload = "{";
    jsonPayload += "\"temperature\":" + String(temp) + ",";
    jsonPayload += "\"humidity\":" + String(hum) + ",";
    jsonPayload += "\"dust\":" + String(dustVal) + ",";
    jsonPayload += "\"turbidity\":" + String(turbVal) + ",";
    jsonPayload += "\"color_temp\":\"" + currentTempColor + "\",";
    jsonPayload += "\"color_humid\":\"" + currentHumColor + "\",";
    jsonPayload += "\"color_dust\":\"" + currentDustColor + "\",";
    jsonPayload += "\"color_turb\":\"" + currentTurbColor + "\"";
    jsonPayload += "}";

    // Publish
    Serial.println(jsonPayload);
    mqttClient.publish(topic, jsonPayload.c_str());
  }
}
